---
// Renders an editable cost/impact table from CMS data.
// rows: [{ label, amount }] — amount is a plain string without the £ sign.
const { rows = [], total, caption } = Astro.props;
---
<figure class="equip">
  <table class="equip-table">
    {caption && <caption>{caption}</caption>}
    <tbody>
      {rows.map((r: { label: string; amount: string }) => (
        <tr><th scope="row">{r.label}</th><td>&pound;{r.amount}</td></tr>
      ))}
    </tbody>
    {total && (
      <tfoot>
        <tr><th scope="row">Total</th><td>&pound;{total}</td></tr>
      </tfoot>
    )}
  </table>
</figure>

<style>
  .equip{margin:28px 0}
  .equip-table{width:100%;border-collapse:collapse;background:var(--card);border:1px solid var(--line);border-radius:14px;overflow:hidden;box-shadow:var(--shadow);font-variant-numeric:tabular-nums}
  .equip-table caption{caption-side:top;text-align:left;font-weight:700;color:var(--blue-dark);margin-bottom:12px;font-size:1.05rem}
  .equip-table th,.equip-table td{padding:13px 18px;border-bottom:1px solid var(--line)}
  .equip-table th{text-align:left;font-weight:600;color:var(--ink)}
  .equip-table td{text-align:right;font-weight:700;color:var(--blue-dark);white-space:nowrap}
  .equip-table tbody tr:nth-child(even){background:var(--bg)}
  .equip-table tfoot th,.equip-table tfoot td{background:var(--blue-dark);color:#fff;font-size:1.06rem;border-bottom:0}
</style>
