---
import Base from '../layouts/Base.astro';

const conventions = [
  {
    year: '2026',
    city: 'Taipei',
    title: 'Come and see us at Booth 1234',
    body: [
      'Do come and see us at our booth in the House of Friendship — Booth number 1234.',
      'Fellowship meeting: Tuesday 16 June, 13:30–14:30 at TaiNEx1, floor 5F, Room 500. This is a unique opportunity for our members to present their projects to a wide audience.',
      'We plan to have four 10-minute presentations. Please write to us with a brief outline of your project before 30 April; if your presentation is selected, we will contact you with more information.',
    ],
    images: [],
    link: null,
  },
  {
    year: '2025',
    city: 'Calgary',
    title: 'The Fellowship’s Annual Dinner',
    body: [
      'Join us for our Annual Dinner on Tuesday 24 June, 6 for 6:30pm at The Westin Calgary Downtown — 320 4 Ave SW, Calgary, AB T2P 2S6.',
      'Canadian $120 per person, including a welcome drink. Scan the QR code on the flyer to book and pay; you will receive an email receipt and ticket.',
    ],
    images: [{ src: '/images/2025/04/image-1.png', alt: 'The Fellowship’s Annual Dinner in Calgary — flyer' }],
    link: { label: 'View more', href: '/images/2025/03/Annual-Dinner-in-Calgary2.pdf' },
  },
  {
    year: '2024',
    city: 'Singapore',
    title: '',
    body: [],
    images: [],
    link: null,
  },
  {
    year: '2023',
    city: 'Melbourne',
    title: 'In the House of Friendship',
    body: [
      'Our booth in the House of Friendship was one of the most colourful and perhaps the busiest. We met many old friends and made many new ones.',
      'We heard so many amazing stories about Rotary’s impact on healthcare in different parts of the world. It never ceases to surprise me that there are hundreds of health programmes initiated by Rotarians, many changing lives. Rotarians invest countless voluntary hours setting up health camps, offering free treatment, transporting medications, and donating medical equipment.',
      'Each programme makes a difference to people’s lives — but how do we measure and quantify our impact, and how do we acknowledge the heroes who provide such service?',
    ],
    images: [],
    link: { label: 'Read our Melbourne report', href: '/images/2023/07/Melbourne-Report-3.pdf' },
  },
];
---
<Base title={"Fellowship at RI — International Rotary Fellowship of Healthcare Professionals"} description={"The International Rotary Fellowship of Healthcare Professionals at Rotary International Conventions — Melbourne 2023, Singapore 2024, Calgary 2025 and Taipei 2026. Come and find us in the House of Friendship."}>
<!-- ============ HERO ============ -->
<header class="ed-hero" data-reveal>
  <div class="ed-hero__media">
    <div class="ed-hero__img" style="background-image:url('/images/2023/07/RIC2023_HOF_GlobalHealthCollaborators-1024x783.jpg')"></div>
    <div class="ed-hero__tint"></div>
    <div class="ed-hero__warm"></div>
    <div class="ed-hero__shade"></div>
    <div class="ed-hero__grain"></div>
  </div>
  <div class="container ed-hero__inner">
    <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>About us · Fellowship at RI</p>
    <h1 class="display ed-hero__title">Where we meet <em>the world.</em></h1>
  </div>
</header>

<!-- ============ LEAD ============ -->
<section class="ed-section">
  <div class="container">
    <div class="ed-head" data-reveal>
      <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>The Fellowship at RI</p>
      <h2 class="ed-title">Every year, in the House of Friendship</h2>
      <p class="ed-sub">At each Rotary International Convention we take our stand in the House of Friendship — meeting old friends, making new ones, and sharing the Fellowship’s work with health professionals from around the world.</p>
    </div>
  </div>
</section>

<!-- ============ CONVENTIONS ============ -->
<section class="ed-section" style="padding-top:0">
  <div class="container">
    <div class="ed-head" data-reveal>
      <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>Recent conventions</p>
      <h2 class="ed-title">Where you’ll find us</h2>
    </div>
    <div class="conv" data-reveal>
      {conventions.map((c) => (
        <div class="conv__item">
          <div class="conv__when">
            <span class="conv__yr">{c.year}</span>
            <span class="conv__city">{c.city}</span>
          </div>
          <div class="conv__body">
            {c.title ? (
              <>
                <h3>{c.title}</h3>
                {c.body.map((p) => (<p>{p}</p>))}
                {c.images.map((img) => (<img class="conv__img" src={img.src} alt={img.alt} loading="lazy" />))}
                {c.link && (<p class="conv__link"><a href={c.link.href} target="_blank" rel="noopener">{c.link.label}</a></p>)}
              </>
            ) : (
              <p class="conv__soon">Details to be confirmed — check back closer to the convention.</p>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .conv{display:grid;gap:20px;max-width:840px}
  .conv__item{display:grid;grid-template-columns:120px 1fr;gap:26px;align-items:start;background:var(--card);border:1px solid var(--line);border-radius:var(--radius-lg);box-shadow:var(--shadow);padding:26px 30px}
  .conv__when{display:flex;flex-direction:column;border-right:1px solid var(--line);padding-right:20px}
  .conv__yr{font-family:var(--serif);font-weight:800;font-size:2rem;line-height:1;color:var(--azure)}
  .conv__city{margin-top:8px;font-size:.72rem;font-weight:800;letter-spacing:.12em;text-transform:uppercase;color:var(--muted)}
  .conv__body h3{font-weight:800;color:var(--blue-dark);font-size:1.15rem;line-height:1.3;margin:0 0 10px}
  .conv__body p{color:var(--ink-2);line-height:1.6;margin:0 0 10px}
  .conv__body p:last-child{margin-bottom:0}
  .conv__img{display:block;width:100%;max-width:360px;border-radius:12px;margin:6px 0 14px;border:1px solid var(--line);box-shadow:var(--shadow)}
  .conv__link a{font-weight:700;color:var(--azure);text-decoration:none}
  .conv__link a:hover{text-decoration:underline}
  .conv__soon{color:var(--muted);font-style:italic}
  @media(max-width:560px){
    .conv__item{grid-template-columns:1fr;gap:14px}
    .conv__when{flex-direction:row;align-items:baseline;gap:12px;border-right:0;border-bottom:1px solid var(--line);padding:0 0 12px}
    .conv__city{margin-top:0}
  }
</style>
</Base>
