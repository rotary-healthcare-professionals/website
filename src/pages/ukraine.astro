---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import ProjectBody from '../components/ProjectBody.astro';

const project = (await getCollection('projects')).find((p) => p.data.slug === 'ukraine');
if (!project) throw new Error("Missing project content: src/content/projects/ukraine.mdoc (slug 'ukraine')");
const d = project.data;
---
<Base title={`${d.title} — International Rotary Fellowship of Healthcare Professionals`} description={d.metaDescription}>
<div class="page-hero">
  <div class="container">
    <p class="crumb"><a href="/">Home</a> / <a href="/projects">Service projects</a></p>
    <h1>{d.title}</h1>
  </div>
</div>

<section>
  <div class="container">
    <div class="prose">
      <ProjectBody project={project} />
    </div>
  </div>
</section>
</Base>
