---
import Base from '../layouts/Base.astro';

const eras = [
  {
    years: '1991',
    name: 'Rotarian Doctors Fellowship',
    body: 'The Rotarian Doctors Fellowship started in 1991 by a small group of Rotarian Doctors in the US headed by Past District Governor Dr. Jim Shamblin (Governor District 6190). Jim’s enthusiasm and personal contact produced a membership list of about 150 in over 30 countries.',
  },
  {
    years: '1993 – 2002',
    name: 'Medicine / Health Vocational Fellowship',
    body: 'RI’s recognition of the group came in 1993 as Medicine/Health Vocational Fellowship – there was a large attendance by members of the new Fellowship in the 1994 RI Convention in Taipei. Jim’s personal commitment and enthusiasm led to membership growth beyond the 300 mark. There were Rotarian Nurses, Podiatrists, and Pharmacists as members. Jim was succeeded by Past Governor and Family Physician, Dr John Neasham (RI District 1040) who served as Chairman from 1996 to 1999. As well as meeting at conventions, there were friendship exchanges by members visiting the US, UK and Turkey. John was succeeded by Obstetrician Gynaecologist Dr Himansu Basu (District 1120) who served as Chairman 1999 to 2002.',
  },
  {
    years: '2002 – 2009',
    name: 'International Fellowship of Rotarian Physicians',
    body: 'Many members felt the need to redefine the activities of the Fellowship to include hands-on efforts of members. This was done and the changes reflected in a change of name – International Fellowship of Rotarian Physicians was recognised by the RI Board in 2002. Dr. Himansu Basu served as Chairman from 2002 to 2009. More professional contacts and activities followed – this included professional visits to Hospitals at the place of Rotary Conventions, presentation of scientific aspects of Rotary programmes and Projects undertaken by membership, Area Scientific Meetings, Scientific Visits and collaboration with other organisations such as Rotary Doctor Bank of Great Britain and Ireland and Men’s Health Network (MHN) – a US based NGO.',
  },
  {
    years: '2009 – 2020',
    name: 'International Fellowship of Rotarian Doctors',
    body: 'With emergence of Rotary Fellowships in Nursing, Plastic Surgery, Dental Volunteers etc. the name and scope were changed. Activities were also focused on larger projects with more emphasis on impact, sustainability and Rotarians involvement — specially vocational expertise for service. Larger sustainable programmes in Tanzania and India were supported by members of the Fellowship. Specially worth mentioning are the Ukerewe and CALMED projects. An active members’ Google group was established in 2007 and this continues to flourish as a resource for information and discussion amongst members. Himansu Basu served as Chairman from 2009 to 2010. PDG Dr John Philip (District 1040, 2008–09), a Surgeon, was Chairman from 2010 to 2023, followed by Herbert Ederer. The programmes have become diverse, reflecting the interests of members, their expertise and hands-on efforts.',
  },
  {
    years: '2020 – present',
    name: 'International Rotary Fellowship of Healthcare Professionals',
    body: 'In 2020 the Fellowship changed its name to acknowledge the trend in health care where professionals from different backgrounds work together in a multidisciplinary and collaborative setting. In 2020 we adopted a new constitution to reflect the change.',
  },
];
---
<Base title={"Our Heritage — International Rotary Fellowship of Healthcare Professionals"} description={"The Rotarian Doctors Fellowship started in 1991 by a small group of Rotarian Doctors in the US headed by Past District Governor Dr. Jim Shamblin. The story of how our Fellowship grew."}>
<!-- ============ HERO ============ -->
<header class="ed-hero ed-hero--soft" data-reveal>
  <div class="ed-hero__media">
    <div class="ed-hero__img" style="background-image:url('/images/2019/02/20170610_174238.jpg')"></div>
    <div class="ed-hero__tint"></div>
    <div class="ed-hero__warm"></div>
    <div class="ed-hero__shade"></div>
    <div class="ed-hero__grain"></div>
  </div>
  <div class="container ed-hero__inner">
    <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>About us · Our heritage</p>
    <h1 class="display ed-hero__title">Our story, <em>since 1991.</em></h1>
  </div>
</header>

<!-- ============ LEAD ============ -->
<section class="ed-section">
  <div class="container ed-head" data-reveal>
    <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>Our heritage</p>
    <h2 class="ed-title">From a handful of Rotarian doctors to a global fellowship</h2>
    <p class="ed-sub">Since 1991 our Fellowship has grown, evolved and changed its name four times — each time widening who belongs and deepening what we do.</p>
  </div>
</section>

<!-- ============ TIMELINE ============ -->
<section class="ed-section" style="padding-top:0">
  <div class="container">
    <div class="tl" data-reveal>
      {eras.map((e) => (
        <div class="tl__item">
          <p class="tl__years">{e.years}</p>
          <h3 class="tl__name">{e.name}</h3>
          <p class="tl__body">{e.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* heritage hero: booth slika je tamna/pretrpana — smanji tint/shade da se pozadina vidi */
  .ed-hero--soft .ed-hero__tint{opacity:.6}
  .ed-hero--soft .ed-hero__img{background-position:center 30%}
  .ed-hero--soft .ed-hero__shade{background:linear-gradient(96deg,rgba(6,17,38,.8) 0%,rgba(6,17,38,.4) 50%,rgba(6,17,38,.1) 100%),linear-gradient(0deg,rgba(6,17,38,.82),transparent 42%)}
  .tl{max-width:780px;margin:0 auto}
  .tl__item{position:relative;padding:0 0 40px 40px}
  .tl__item::before{content:"";position:absolute;left:5px;top:8px;bottom:-4px;width:2px;background:var(--line)}
  .tl__item:last-child::before{display:none}
  .tl__item:last-child{padding-bottom:0}
  .tl__item::after{content:"";position:absolute;left:0;top:5px;width:12px;height:12px;border-radius:50%;background:var(--gold);box-shadow:0 0 0 4px rgba(244,168,28,.16)}
  .tl__years{font-size:.8rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:var(--azure);margin:0}
  .tl__name{font-family:var(--serif);font-weight:800;font-size:clamp(1.2rem,2.4vw,1.55rem);color:var(--blue-dark);line-height:1.25;margin:6px 0 12px}
  .tl__body{color:var(--ink-2);line-height:1.7;margin:0}
  @media(max-width:600px){.tl__item{padding-left:32px}}
</style>
</Base>
