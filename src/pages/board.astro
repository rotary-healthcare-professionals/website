---
import Base from '../layouts/Base.astro';

// Board of Directors 2025-26 — 17 Directors from 10 countries.
const directors = [
  { name: 'Herbert Ederer', country: 'Austria', role: 'Chair' },
  { name: 'Amal El Sisi', country: 'Egypt', role: 'Vice Chair' },
  { name: 'Ann Evans', country: 'USA', role: 'Vice Chair · Preventable Blindness' },
  { name: 'Rainer Moosdorf', country: 'Germany', role: 'Secretary' },
  { name: 'John Philip', country: 'UK', role: 'Treasurer · Signatory · Trustee' },
  { name: 'Gillian Pearce', country: 'UK', role: 'Signatory · Trustee' },
  { name: 'Demetress Harrell', country: 'USA', role: 'Medical Equipment' },
  { name: 'Richard Kalungi', country: 'Uganda', role: 'Uganda' },
  { name: 'Drago Pausek', country: 'Croatia', role: 'Webmaster · Signatory · Trustee' },
  { name: 'Pat Merryweather-Arges', country: 'USA', role: 'Quality & Patient Safety' },
  { name: 'Douglas Donald McMillan', country: 'Canada', role: 'Newborn Care' },
  { name: 'Francisco Rosiello', country: 'Italy', role: 'Disaster Medicine · Medical Intelligence' },
  { name: 'K V Ravishankar', country: 'India', role: 'Preventable Blindness' },
  { name: 'Surinder Pal Singh Grover', country: 'India', role: 'IRFHP Branches' },
  { name: 'Saroj Bajracharya', country: 'Nepal', role: 'IRFHP Branches' },
  { name: 'Maimuna Alex-Adeomi', country: 'USA', role: 'Patient Safety' },
  { name: 'Bagathsingh Karuppanan', country: 'India', role: 'IRFHP Branches' },
];
const isOfficer = (role) => /Chair|Secretary|Treasurer/.test(role);

const chairCreds = [
  'Rotary Passport Club — co Planet D1900',
  'Rotary Club Weiz D1910 — Gründungspräsident 2006–07 & Präsident 2007–08',
  'AG D1910 2009–11 · District Governor (DG) D1910 2012–13',
  'District Rotary Foundation Committee Chair (DRFCC) D1910 2013–15',
  'Rotary Foundation Coordinator (RRFC) Zone 19p 2015–18 · ARRFC Z21A 2018–20',
  'Endowment Major Gift Advisor (EMGA) Zone 21A 2020–23',
];

const reports = [
  { name: 'Message from our incoming Chair (2023)', href: '/images/2023/07/New-Board-and-Herberts-words.pdf' },
  { name: '‘Thank you’ from our outgoing Chair (2023)', href: '/images/2023/07/Thank-you-from-outgoing-chair.pdf' },
  { name: 'Chairman’s Report 2023 — a year of achievement & our support to Ukraine', href: '/images/2023/07/CHAIRMANS-REPORT-2023.pdf' },
];
const accounts = [
  { name: 'Annual accounts 2021–22', href: '/images/2023/07/Draft-accounts-IRFHP-Trust-2022.pdf' },
  { name: 'Annual accounts 2022–23', href: '/images/2024/07/Final-accounts-IRFHP-Trust-2023-2.pdf' },
  { name: 'Annual accounts 2023–24', href: '/images/2024/07/Final-accounts-IRFHP-Trust-2023-3.pdf' },
  { name: 'Annual accounts 2024–25', href: '/images/2025/02/2024-Final-accounts-IRFHP-signed.pdf' },
];
---
<Base
  title={"Our Board and Accounts — International Rotary Fellowship of Healthcare Professionals"}
  description={"Our governance, Board of Directors and published accounts. The IRFHP is led by an international Board of 17 Directors from 10 countries, elected under our Constitution and Bylaws, meeting monthly online."}
>
<!-- ============ HERO ============ -->
<header class="ed-hero" data-reveal>
  <div class="ed-hero__media">
    <div class="ed-hero__img" style="background-image:url('/images/2023/07/RIC2023_HOF_GlobalHealthCollaborators-1024x783.jpg')"></div>
    <div class="ed-hero__tint"></div>
    <div class="ed-hero__warm"></div>
    <div class="ed-hero__shade"></div>
    <div class="ed-hero__grain"></div>
  </div>
  <div class="container ed-hero__inner">
    <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>About us · Our Board and Accounts</p>
    <h1 class="display ed-hero__title">Led by an international <em>Board of Directors.</em></h1>
  </div>
</header>

<!-- ============ GOVERNANCE ============ -->
<section class="ed-section">
  <div class="container ed-head" data-reveal>
    <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>Governance & accountability</p>
    <h2 class="ed-title">We govern ourselves — openly and accountably</h2>
    <p class="ed-sub">The International Rotary Fellowship of Healthcare Professionals is led by an international Board of Directors who meet monthly online. Directors are elected in accordance with the Fellowship’s Constitution and Bylaws, ensuring transparent and accountable governance.</p>
    <p class="ed-sub" style="margin-top:14px">As one of Rotary’s most active Fellowships, we maintain a vibrant programme of global activities, professional exchanges, humanitarian initiatives and collaborative learning. We warmly encourage members to connect with us, take part in our work and strengthen our shared impact.</p>
  </div>
</section>

<!-- ============ CHAIR ============ -->
<section class="ed-section" style="padding-top:0">
  <div class="container">
    <div class="ed-head" data-reveal>
      <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>Our Chair</p>
      <h2 class="ed-title">Leading the Fellowship</h2>
    </div>
    <div class="chair" data-reveal>
      <figure class="chair__photo">
        <img src="/images/2025/02/Herbert.jpg" alt="Dr. med. Herbert Ederer, Chair of the Fellowship" loading="lazy" />
      </figure>
      <div class="chair__body">
        <p class="chair__role">Chair · Austria</p>
        <p class="chair__name">Dr. med. Herbert Ederer</p>
        <p class="chair__loc">Decades of Rotary leadership and Foundation service</p>
        <ul class="chair__creds">
          {chairCreds.map((c) => (<li>{c}</li>))}
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ============ THE BOARD ============ -->
<section class="ed-section" style="padding-top:0">
  <div class="container">
    <div class="ed-head" data-reveal>
      <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>The Board of Directors 2025–26</p>
      <h2 class="ed-title">A talented, international team</h2>
      <p class="ed-sub">Seventeen Directors from ten different countries, bringing together medicine, nursing, public health and humanitarian leadership. We meet once a month online.</p>
    </div>
    <div class="board-table-wrap" data-reveal>
      <table class="board-table">
        <thead>
          <tr><th scope="col">Director</th><th scope="col">Role</th><th scope="col" class="col-country">Country</th></tr>
        </thead>
        <tbody>
          {directors.map((d) => (
            <tr class={isOfficer(d.role) ? 'is-officer' : ''}>
              <th scope="row">{d.name}</th>
              <td>{d.role}</td>
              <td class="col-country">{d.country}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- ============ DOCUMENTS & ACCOUNTS ============ -->
<section class="ed-section" style="padding-top:0">
  <div class="container">
    <div class="ed-head" data-reveal>
      <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>Transparency</p>
      <h2 class="ed-title">Documents & accounts</h2>
      <p class="ed-sub">Our reports and full financial accounts, published openly. Every document opens or downloads directly.</p>
    </div>
    <div class="cards-2" data-reveal style="margin-top:40px">
      <div>
        <h3 class="gov-h">Reports & messages</h3>
        {reports.map((d) => (
          <a class="doc-card" href={d.href} target="_blank" rel="noopener">
            <span class="doc-ico doc-pdf">PDF</span>
            <span class="doc-meta"><span class="doc-name">{d.name}</span><span class="doc-sub">PDF · Download</span></span>
            <span class="doc-open">↓</span>
          </a>
        ))}
      </div>
      <div>
        <h3 class="gov-h">Annual accounts</h3>
        {accounts.map((d) => (
          <a class="doc-card" href={d.href} target="_blank" rel="noopener">
            <span class="doc-ico doc-pdf">PDF</span>
            <span class="doc-meta"><span class="doc-name">{d.name}</span><span class="doc-sub">PDF · Download</span></span>
            <span class="doc-open">↓</span>
          </a>
        ))}
      </div>
    </div>
    <p class="acct-note" data-reveal>
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/></svg>
      Our accounts are also published on the Charity Commission register. <a href="https://register-of-charities.charitycommission.gov.uk/charity-search/-/charity-details/5172968" target="_blank" rel="noopener">View our Charity Commission entry</a>.
    </p>
  </div>
</section>

<!-- ============ CLOSING CTA ============ -->
<section class="ed-section" style="padding-top:0">
  <div class="container">
    <div class="join-cta" data-reveal>
      <div class="join-cta__img" style="background-image:url('/images/2024/07/Homepage-main-photo.jpg')"></div>
      <div class="join-cta__grade"></div>
      <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>Join us</p>
      <h2>Bring your skills to a global family.</h2>
      <p>Open to all health professionals — Rotarian and non-Rotarian. All it takes is a heart to do good.</p>
      <div class="join-cta__actions">
        <a class="btn btn-primary" href="/membership">Become a member</a>
        <a class="btn btn-outline" href="/contact">Contact us</a>
      </div>
    </div>
  </div>
</section>

</Base>
