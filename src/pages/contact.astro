---
import Base from '../layouts/Base.astro';

const email = 'rotaryhealthprofessionals@gmail.com';
const mapQuery = 'Highfield House, Red Shute Hill, Thatcham, RG18 9QH';
const mapLink = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(mapQuery)}`;

const branches = [
  // Big Ben (Elizabeth Tower) silhouette — clock knocked out via evenodd
  { label: 'Headquarters', name: 'United Kingdom', icon: '<path d="M12 1.2l1.7 3.4h-3.4z"/><path d="M10.6 4.9h2.8v1.5h-2.8z"/><path d="M9.3 6.6h5.4v4.6H9.3zM13.25 8.9a1.25 1.25 0 1 1-2.5 0 1.25 1.25 0 0 1 2.5 0z"/><path d="M10.2 11.2h3.6v9.8h-3.6z"/><path d="M9 21h6v2H9z"/>' },
  // Pyramids of Giza silhouette + sun + sand baseline
  { label: 'Active branch', name: 'Egypt', icon: '<path d="M14 6.8 23 20.6H5z"/><path d="M7.4 11.4 14 20.6H.8z"/><circle cx="6.4" cy="6.2" r="1.9"/><path d="M.8 20.4h22.4v1.7H.8z"/>' },
  // Grey crowned crane (Uganda national bird) silhouette
  { label: 'Active branch', name: 'Uganda', icon: '<path d="M10.3 13.8h.9l.3 7.6h-1z"/><path d="M12.8 13.8h.9l.4 7.6h-1z"/><path d="M9.6 21h2.4v.9H9.6z"/><path d="M12.4 21h2.5v.9h-2.5z"/><ellipse cx="11" cy="12" rx="4.9" ry="3.3"/><path d="M6.4 10.4 1 7 6.9 12.2z"/><path d="M11.9 9.6c.1-2.7 1.9-4.6 4.1-5.6l1 1.6c-2 .9-3.4 2.4-3.4 4.6z"/><circle cx="17" cy="3.8" r="1.55"/><path d="M18.3 3.5 21.6 2.9 18.4 4.7z"/><path d="M16.9 2.5 16.2 .2 17.2 2.4z"/><path d="M15.9 2.8 14.7 .8 16.5 2.7z"/><path d="M17.8 2.7 19 .9 18.2 2.8z"/>' },
];
---
<Base title={"Contact Us — International Rotary Fellowship of Healthcare Professionals"} description={"We are ready to answer all your questions and help you find the best cause to help. Contact the International Rotary Fellowship of Healthcare Professionals."}>
<!-- ============ HERO ============ -->
<header class="ed-hero" data-reveal>
  <div class="ed-hero__media">
    <div class="ed-hero__img" style="background-image:url('/images/2025/02/seth-doyle-78210-unsplash-copyright-min-1.jpg')"></div>
    <div class="ed-hero__tint"></div>
    <div class="ed-hero__warm"></div>
    <div class="ed-hero__shade"></div>
    <div class="ed-hero__grain"></div>
  </div>
  <div class="container ed-hero__inner">
    <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>Contact</p>
    <h1 class="display ed-hero__title">Let&rsquo;s start a <em>conversation.</em></h1>
  </div>
</header>

<!-- ============ GET IN TOUCH (form + reach us) ============ -->
<section class="ed-section">
  <div class="container ed-head" data-reveal>
    <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>Get in touch</p>
    <h2 class="ed-title">We&rsquo;re ready to help</h2>
    <p class="ed-sub">Whether you want to join, collaborate on a health programme, or simply learn more about our work — we would love to hear from you.</p>
  </div>
  <div class="container">
    <div class="contact-grid" data-reveal>
      <!-- Form -->
      <div class="contact-formwrap">
        <h2>Send us a message</h2>
        <form id="contactForm" class="contact-form" action={`https://formsubmit.co/${email}`} method="POST">
          <input type="hidden" name="_subject" value="New enquiry from the IRFHP website">
          <input type="hidden" name="_captcha" value="false">
          <input type="hidden" name="_template" value="table">
          <input type="text" name="_honey" tabindex="-1" autocomplete="off" class="hp" aria-hidden="true">
          <label>Your name
            <input type="text" name="name" required autocomplete="name">
          </label>
          <label>Your e-mail
            <input type="email" name="email" required autocomplete="email">
          </label>
          <label>Message
            <textarea name="message" rows="5" required></textarea>
          </label>
          <button type="submit" class="btn btn-primary">Send message</button>
        </form>
        <p id="formStatus" class="form-status" role="status" aria-live="polite"></p>
        <p class="form-note">Your message is sent straight to our inbox — we usually reply within a few working days.</p>
      </div>

      <!-- Reach us -->
      <div class="contact-info">
        <h2>How to reach us</h2>
        <ul class="contact-methods">
          <li>
            <span class="ci"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/></svg></span>
            <div class="ci-body">
              <span class="ci-label">E-mail</span>
              <a href={`mailto:${email}`}>{email}</a>
            </div>
            <button type="button" class="copy-btn" data-copy={email} aria-label="Copy e-mail address">
              <svg class="ico-copy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              <svg class="ico-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </button>
          </li>
          <li>
            <span class="ci"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg></span>
            <div class="ci-body">
              <span class="ci-label">Phone</span>
              <a href="tel:+442071932137">+44 (0)20 7193 2137</a>
            </div>
            <button type="button" class="copy-btn" data-copy="+44 (0)20 7193 2137" aria-label="Copy phone number">
              <svg class="ico-copy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              <svg class="ico-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </button>
          </li>
          <li>
            <span class="ci"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg></span>
            <div class="ci-body">
              <span class="ci-label">Address</span>
              <span class="ci-val">Highfield House, Red Shute Hill, Thatcham, RG18 9QH, United Kingdom</span>
              <a class="map-open" href={mapLink} target="_blank" rel="noopener">View on Google Maps <span class="ext-arrow" aria-hidden="true">↗</span></a>
            </div>
          </li>
          <li>
            <span class="ci"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12z"/></svg></span>
            <div class="ci-body">
              <span class="ci-label">Facebook</span>
              <a href="https://www.facebook.com/people/Fellowship-of-Healthcare-Professionals/100080617180613/" target="_blank" rel="noopener">Fellowship of Healthcare Professionals <span class="ext-arrow" aria-hidden="true">↗</span></a>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ============ BRANCHES (silhouettes) ============ -->
<section class="ed-section" style="padding-top:0">
  <div class="container">
    <div class="ed-head" data-reveal>
      <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>Global thinking, local action</p>
      <h2 class="ed-title">Where we work</h2>
      <p class="ed-sub">Alongside our UK base, we have active branches in Egypt and Uganda — all reachable through the details above.</p>
    </div>
    <div class="cards-3" data-reveal>
      {branches.map((b) => (
        <div class="info-card center branch-card">
          <span class="branch-ico"><svg viewBox="0 0 24 24" fill="currentColor" fill-rule="evenodd" set:html={b.icon} /></span>
          <span class="branch-label">{b.label}</span>
          <h3>{b.name}</h3>
        </div>
      ))}
    </div>
  </div>
</section>

<script is:inline>
(function () {
  /* Kontakt-forma preko FormSubmit AJAX-a — poruka ide ravno u inbox, ostaje na stranici */
  var form = document.getElementById('contactForm');
  var status = document.getElementById('formStatus');
  if (form && status) {
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var hp = form.querySelector('.hp'); if (hp && hp.value) return; // spam trap
      var btn = form.querySelector('button[type=submit]');
      var orig = btn.textContent;
      btn.disabled = true; btn.textContent = 'Sending…';
      status.className = 'form-status';
      fetch(form.getAttribute('action').replace('formsubmit.co/', 'formsubmit.co/ajax/'), {
        method: 'POST', headers: { 'Accept': 'application/json' }, body: new FormData(form)
      }).then(function (r) { return r.json(); }).then(function (res) {
        if (res.success === 'true' || res.success === true) {
          form.style.display = 'none';
          status.className = 'form-status ok';
          status.textContent = 'Thank you — your message has been sent. We will get back to you soon.';
        } else { throw new Error(); }
      }).catch(function () {
        btn.disabled = false; btn.textContent = orig;
        status.className = 'form-status err';
        status.innerHTML = 'Sorry, something went wrong. Please e-mail us directly at <a href="mailto:rotaryhealthprofessionals@gmail.com">rotaryhealthprofessionals@gmail.com</a>.';
      });
    });
  }

  /* Klikni za kopiranje (e-mail / telefon) */
  [].forEach.call(document.querySelectorAll('.copy-btn'), function (b) {
    b.addEventListener('click', function () {
      var t = b.getAttribute('data-copy');
      if (!navigator.clipboard) return;
      navigator.clipboard.writeText(t).then(function () {
        b.classList.add('copied');
        setTimeout(function () { b.classList.remove('copied'); }, 1400);
      });
    });
  });
})();
</script>
</Base>
