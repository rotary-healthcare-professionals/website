---
import Base from '../layouts/Base.astro';

const mapQuery = 'Highfield House, Red Shute Hill, Thatcham, RG18 9QH';
const mapEmbed = `https://maps.google.com/maps?q=${encodeURIComponent(mapQuery)}&z=15&output=embed`;
const mapLink = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(mapQuery)}`;
---
<Base title={"Contact Us — International Rotary Fellowship of Healthcare Professionals"} description={"We are ready to answer all your questions and help you find the best cause to help. Contact the International Rotary Fellowship of Healthcare Professionals."}>
<div class="page-hero">
  <div class="container">
    <p class="crumb"><a href="/">Home</a> / Contact</p>
    <h1>Contact Us</h1>
  </div>
</div>

<section>
  <div class="container">
    <p class="section-lead">We are ready to answer all your questions and help you find the best cause to help.</p>

    <div class="contact-grid">
      <div class="contact-info">
        <h2>How to reach us</h2>
        <ul class="contact-methods">
          <li>
            <span class="ci"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/></svg></span>
            <div class="ci-body">
              <span class="ci-label">E-mail</span>
              <a href="mailto:rotaryhealthprofessionals@gmail.com">rotaryhealthprofessionals@gmail.com</a>
            </div>
          </li>
          <li>
            <span class="ci"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg></span>
            <div class="ci-body">
              <span class="ci-label">Phone</span>
              <a href="tel:+442071932137">+44 (0)20 7193 2137</a>
            </div>
          </li>
          <li>
            <span class="ci"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg></span>
            <div class="ci-body">
              <span class="ci-label">Address</span>
              <span class="ci-val">Highfield House, Red Shute Hill, Thatcham, RG18 9QH, United Kingdom</span>
            </div>
          </li>
          <li>
            <span class="ci"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12z"/></svg></span>
            <div class="ci-body">
              <span class="ci-label">Facebook</span>
              <a href="https://www.facebook.com/people/Fellowship-of-Healthcare-Professionals/100080617180613/" target="_blank" rel="noopener">Fellowship of Healthcare Professionals <span class="ext-arrow" aria-hidden="true">↗</span></a>
            </div>
          </li>
        </ul>
        <a class="btn btn-primary" href="mailto:rotaryhealthprofessionals@gmail.com">Send us an e-mail</a>
      </div>

      <div class="contact-map">
        <iframe class="map-frame" src={mapEmbed} title="Map showing Highfield House, Red Shute Hill, Thatcham" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        <a class="map-open" href={mapLink} target="_blank" rel="noopener">Open in Google Maps <span class="ext-arrow" aria-hidden="true">↗</span></a>
      </div>
    </div>

    <div class="branches">
      <h2>Our branches</h2>
      <p class="section-lead">Alongside the United Kingdom we have active branches in Egypt and Uganda. Enquiries for all branches are handled through the same contact details above.</p>
      <div class="branch-chips">
        <span>United Kingdom</span>
        <span>Egypt</span>
        <span>Uganda</span>
      </div>
    </div>
  </div>
</section>
</Base>
