---
import Base from '../layouts/Base.astro';

const programmes = [
  'A mental health programme in Brazil',
  'Screening for oral cancer in India',
  'A diabetic clinic in Venezuela',
  'A general clinic in Mexico',
  'Music therapy in Idaho',
  'Dental and eye care in Uganda',
  'A cervical cancer screening programme in India',
  'A vision and dental clinic for the Bwindi Community',
];
---
<Base title={"A Directory of Health Programmes — International Rotary Fellowship of Healthcare Professionals"} description={"Many Rotarians are actively involved in programmes aimed at enhancing healthcare. Our goal is to create an open directory of health programmes to share experiences and lessons."}>
<!-- ============ HERO ============ -->
<header class="ed-hero" data-reveal>
  <div class="ed-hero__media">
    <div class="ed-hero__img" style="background-image:url('/images/2025/02/annie-spratt-427337-unsplash-copyright.jpg')"></div>
    <div class="ed-hero__tint"></div>
    <div class="ed-hero__warm"></div>
    <div class="ed-hero__shade"></div>
    <div class="ed-hero__grain"></div>
  </div>
  <div class="container ed-hero__inner">
    <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>About us · Directory of Health Programmes</p>
    <h1 class="display ed-hero__title">An open directory of <em>health programmes.</em></h1>
  </div>
</header>

<!-- ============ LEAD ============ -->
<section class="ed-section">
  <div class="container">
    <div class="ed-head" data-reveal>
      <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>Share and learn</p>
      <h2 class="ed-title">Learning from one another</h2>
      <p class="ed-sub">We often hear amazing stories about Rotary’s impact on healthcare in different parts of the world.</p>
    </div>
    <div class="prose" data-reveal style="max-width:760px;margin:20px 0 0">
      <p>There are hundreds of health programmes initiated by Rotarians, many changing lives. Rotarians invest countless voluntary hours setting up health camps, offering free treatment, transporting medications and donating medical equipment.</p>
      <p>At present we also do not have a way of sharing our experiences and learning from each other. Valuable lessons learned are lost in the mist of time.</p>
      <p>We have decided to compile an open Directory of Health Programmes — for sharing and encouraging one another.</p>
    </div>
  </div>
</section>

<!-- ============ PROGRAMMES ============ -->
<section class="ed-section" style="padding-top:0">
  <div class="container">
    <div class="ed-head" data-reveal>
      <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>What has been shared</p>
      <h2 class="ed-title">Programmes Rotarians have shared</h2>
    </div>
    <div class="dir-grid" data-reveal>
      {programmes.map((p) => (
        <div class="dir-item">{p}</div>
      ))}
    </div>
  </div>
</section>

<!-- ============ CTA ============ -->
<section class="ed-section" style="padding-top:0">
  <div class="container">
    <div class="dir-cta" data-reveal>
      <h3>Involved in a health programme?</h3>
      <p>If you are involved in a health programme, please share information about your work with other like-minded people. Register your programme below, and see a list of programmes from different parts of the world.</p>
      <div class="dir-cta__actions">
        <a class="btn btn-primary" href="https://form.jotform.com/232014525247852" target="_blank" rel="noopener">Join the Directory</a>
        <a class="btn btn-outline dir-cta__ghost" href="/images/2025/02/ROTARY_HEALTH_PROGRAMMES.xlsx" target="_blank" rel="noopener">See the full list (XLSX)</a>
      </div>
    </div>
  </div>
</section>

<style>
  .dir-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;max-width:860px;margin-top:28px}
  @media(max-width:640px){.dir-grid{grid-template-columns:1fr}}
  .dir-item{display:flex;align-items:center;gap:13px;background:var(--card);border:1px solid var(--line);border-radius:14px;padding:16px 20px;box-shadow:var(--shadow);font-weight:700;color:var(--blue-dark);line-height:1.4}
  .dir-item::before{content:"";flex:none;width:9px;height:9px;border-radius:50%;background:var(--gold)}
  .dir-cta{max-width:860px;background:var(--card);border:1px solid var(--line);border-radius:var(--radius-lg);box-shadow:var(--shadow);padding:clamp(26px,4vw,40px)}
  .dir-cta h3{font-family:var(--serif);font-weight:800;font-size:clamp(1.3rem,2.6vw,1.7rem);color:var(--blue-dark);margin:0 0 10px}
  .dir-cta p{color:var(--ink-2);line-height:1.6;margin:0 0 20px;max-width:60ch}
  .dir-cta__actions{display:flex;flex-wrap:wrap;gap:12px}
  /* outline gumb je bijeli (za tamne heroje) — na svijetloj kartici treba azurni obrub */
  .dir-cta__ghost{border-color:var(--azure);color:var(--azure)}
  .dir-cta__ghost:hover{background:var(--azure);border-color:var(--azure);color:#fff}
</style>
</Base>
