---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import impact from '../data/impact.json';
const projects = (await getCollection('projects'))
  .sort((a, b) => (a.data.order ?? 100) - (b.data.order ?? 100));
---
<Base title={"Service projects — International Rotary Fellowship of Healthcare Professionals"} description={"Our humanitarian service projects: Kangaroo Mother Care, Ukraine, cervical cancer prevention, Tanzania and more — channelling the skills of health professionals to help those in need."}>
<header class="ed-hero ed-hero--brand" data-reveal>
  <div class="ed-hero__media">
    <div class="ed-hero__warm"></div>
    <div class="ed-hero__grain"></div>
  </div>
  <div class="container ed-hero__inner">
    <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>Service projects</p>
    <h1 class="display ed-hero__title">Channelling skills, <em>changing lives.</em></h1>
  </div>
</header>

<section>
  <div class="container">
    <div class="center" style="max-width:760px;margin:0 auto">
      <span class="kicker">Programmes</span>
      <h2 class="section-title">Together we can provide better lives</h2>
      <p class="section-lead">One of our aims is to channel the energy, resources and skills of health professionals – members and those not yet members – to help those in need. The pandemic has widened the gulf in healthcare between high- and low-income countries; there is a desperate need for professionals to come together and channel their skills in a sustainable way to improve health care.</p>
    </div>

    <div class="proj-grid">
      {projects.map((p) => {
        const ext = Boolean(p.data.externalUrl);
        const href = p.data.externalUrl || `/${p.data.slug}`;
        return (
          <article class="proj-card">
            {p.data.coverImage && (
              <a href={href} target={ext ? '_blank' : undefined} rel={ext ? 'noopener' : undefined} class="proj-card__media">
                <img src={p.data.coverImage} alt={p.data.navLabel || p.data.title} loading="lazy" />
              </a>
            )}
            <div class="proj-card__body">
              <h3>{p.data.navLabel || p.data.title}</h3>
              <p>{p.data.summary}</p>
              <a class="btn btn-blue" href={href} target={ext ? '_blank' : undefined} rel={ext ? 'noopener' : undefined}>
                {ext ? 'Learn more ↗' : 'Read more'}
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<!-- IMPACT -->
<section class="impact-band" style="padding:52px 0">
  <div class="container impact">
    {impact.projects.map((s) => (
      <div class="item"><div class="n">{s.value}</div><div class="l">{s.label}</div></div>
    ))}
  </div>
</section>

<!-- CTA -->
<section>
  <div class="container center">
    <h2 class="section-title">Get involved</h2>
    <p class="section-lead">Partnering with us lets you make real, lasting change. Broaden your reach and impact today.</p>
    <p style="margin-top:22px"><a class="btn btn-primary" href="/membership">Partner with us</a></p>
  </div>
</section>
</Base>
