---
import Base from '../layouts/Base.astro';

const aims = [
  'Encourage fellowship among healthcare professionals.',
  'Take part in health programmes — volunteering, advising, training and sharing experience.',
  'Keep members connected through visits, exchanges and online.',
  'Recognise those who give exceptional service.',
  'Collaborate with professional bodies and governmental and non-governmental agencies.',
];

const govDocs = [
  { name: 'Our constitution', type: 'PDF', cls: 'doc-pdf', href: '/images/2022/07/Rotary_Fellowship_Healthcare_Proff_Constit-2.pdf' },
  { name: 'Our Trust governing document', type: 'PDF', cls: 'doc-pdf', href: '/images/2022/07/Trust-deed-signed-final-3.pdf' },
  { name: 'Our bylaws', type: 'DOC', cls: 'doc-word', href: '/images/2025/03/Rotary_Fellowship_Healthcare_Proff_Bylaws_amended2.docx' },
];

const policies = [
  { name: 'Data Protection', href: '/images/2024/12/Data-Protection-Policy_2024-1.pdf' },
  { name: 'Risk Management', href: '/images/2024/12/Risk-Management-Policy_2024.pdf' },
  { name: 'Equality & Diversity', href: '/images/2024/12/Equality-and-Diversity-Policy_2024.pdf' },
  { name: 'Dignity', href: '/images/2024/12/Dignity-Policy_2024.pdf' },
  { name: 'Anti-Fraud & Anti-Corruption', href: '/images/2024/12/Anti-Fraud-and-Anti-Corruption-Policy_2024-1.pdf' },
];

const subgroups = [
  {
    acr: 'HOPS', name: 'Health Outcomes & Patient Safety',
    mission: 'Provide support to achieve the highest quality health services in a safe environment for patients and health care workers.',
    vision: 'A world in which no patient is harmed in health care, and everyone receives safe and respectful care — every time, everywhere.',
  },
  {
    acr: 'SASMES', name: 'Safe & Sustainable Medical Equipment Supply',
    mission: 'Encourage and assist Rotarians to improve patient care by responding, in a safe and sustainable manner, to requests for new or repurposed medical devices that meet the proven health needs of their communities.',
    vision: 'A world where everyone has access to quality healthcare, supported by appropriate, affordable and sustainable medical devices.',
  },
];

const branches = [
  { label: 'Headquarters', name: 'United Kingdom', d: 'Our registered base, where the Fellowship’s humanitarian work is coordinated.', icon: '<path d="M9 21h6"/><path d="M9.7 21V10h4.6v11"/><circle cx="12" cy="7.4" r="2"/><path d="M12 6.2v1.2l.9.6"/><path d="M10 4.6h4"/><path d="M12 1.6 10 4.6h4L12 1.6Z"/>' },
  { label: 'Active branch', name: 'Egypt', d: 'Home of Heart2Heart, providing free cardiac care for children with congenital heart conditions.', icon: '<path d="M12 4 3 20h18L12 4Z"/><path d="M12 4 8.7 20M12 4l3.3 16"/><circle cx="18.6" cy="6.4" r="1.5"/>' },
  { label: 'Active branch', name: 'Uganda', d: 'Dental and eye care outreach reaching communities across the country.', icon: '<path d="M3 15c2.5 1.5 6 1.4 8-1.2"/><path d="M3 15c1 2.6 4 3.6 7 2.6"/><path d="M11 13.8c1-3 2-4.6 4.4-5.6"/><circle cx="16.6" cy="7.4" r="1.2"/><path d="M17.7 7.1 19.5 6.5"/><path d="M15.8 6.1 15 4.5M16.6 5.9 16.5 4.1M17.4 6.1 18.1 4.6"/><path d="M7 17.4V20M10 17V20"/>' },
];

const explore = [
  { h: 'Our journey', d: 'The story of how our Fellowship grew.', href: '/our-journey' },
  { h: 'Our heritage', d: 'The people and history behind us.', href: '/heritage' },
  { h: 'Our board & accounts', d: 'Directors, governance and published accounts.', href: '/board' },
  { h: 'Directory of Health Programmes', d: 'An open directory of Rotary health programmes worldwide.', href: '/directory' },
  { h: 'Rotary International Conventions', d: 'Where to meet us around the world.', href: '/conventions' },
];
---
<Base
  title={"About us — International Rotary Fellowship of Healthcare Professionals"}
  description={"Who we are: a global family of healthcare professionals united by 'service above self'. Our aims, governance, subgroups and branches."}
>
<!-- ============ HERO ============ -->
<header class="ed-hero" data-reveal>
  <div class="ed-hero__media">
    <div class="ed-hero__img" style="background-image:url('/images/2023/07/RIC2023_HOF_GlobalHealthCollaborators-1024x783.jpg')"></div>
    <div class="ed-hero__tint"></div>
    <div class="ed-hero__warm"></div>
    <div class="ed-hero__shade"></div>
    <div class="ed-hero__grain"></div>
  </div>
  <div class="container ed-hero__inner">
    <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>About us</p>
    <h1 class="display ed-hero__title">A global family, united by <em>‘service above self.’</em></h1>
  </div>
</header>

<!-- ============ WHO WE ARE ============ -->
<section class="ed-section">
  <div class="container ed-head" data-reveal>
    <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>Who we are</p>
    <h2 class="ed-title">The natural home of every healthcare professional — Rotarian and non-Rotarian.</h2>
    <p class="ed-sub">Rotary Fellowships are international groups who share a common passion. Ours brings health professionals together across the world to make friends, share knowledge — and combine fellowship with action.</p>
  </div>
</section>

<!-- ============ AIMS ============ -->
<section class="ed-section" style="padding-top:0">
  <div class="container">
    <div class="ed-head" data-reveal>
      <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>What we set out to do</p>
      <h2 class="ed-title">Our aims</h2>
    </div>
    <div class="goals">
      {aims.map((g, i) => (
        <div class="goal" data-reveal style={`--d:${i * 0.06}s`}>
          <span class="goal__n">{String(i + 1).padStart(2, '0')}</span>
          <p class="goal__t">{g}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ============ GOVERNANCE ============ -->
<section class="ed-section" style="padding-top:0">
  <div class="container">
    <div class="ed-head" data-reveal>
      <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>Governance</p>
      <h2 class="ed-title">We set our own course</h2>
      <p class="ed-sub">We have our own constitution, governance structure and decide our own activities. This Fellowship operates in compliance with Rotary International’s policies for Rotary Fellowships, but is not an agency of — or controlled by — Rotary International.</p>
    </div>
    <div class="cards-2" data-reveal>
      <div>
        <h3 class="gov-h">Governing documents</h3>
        {govDocs.map((d) => (
          <a class="doc-card" href={d.href} target="_blank" rel="noopener">
            <span class={`doc-ico ${d.cls}`}>{d.type}</span>
            <span class="doc-meta"><span class="doc-name">{d.name}</span><span class="doc-sub">{d.type} · Download</span></span>
            <span class="doc-open">↓</span>
          </a>
        ))}
      </div>
      <div>
        <h3 class="gov-h">Our policies</h3>
        <div class="policy-links">
          {policies.map((p) => (
            <a href={p.href} target="_blank" rel="noopener">{p.name}</a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ SUBGROUPS ============ -->
<section class="ed-section" style="padding-top:0">
  <div class="container">
    <div class="ed-head" data-reveal>
      <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>How we focus</p>
      <h2 class="ed-title">Our subgroups</h2>
      <p class="ed-sub">Members can put their energy where it matters most through two focused subgroups.</p>
    </div>
    <div class="cards-2" data-reveal>
      {subgroups.map((s) => (
        <div class="info-card">
          <span class="tier__badge">{s.acr}</span>
          <h3 style="margin-top:14px">{s.name}</h3>
          <p><strong>Mission</strong> — {s.mission}</p>
          <p style="margin-top:10px"><strong>Vision</strong> — {s.vision}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ============ BRANCHES ============ -->
<section class="ed-section" style="padding-top:0">
  <div class="container">
    <div class="ed-head" data-reveal>
      <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>Global thinking, local action</p>
      <h2 class="ed-title">Where we work</h2>
      <p class="ed-sub">We think globally and act locally.</p>
    </div>
    <div class="cards-3" data-reveal>
      {branches.map((b) => (
        <div class="info-card center branch-card">
          <span class="branch-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={b.icon} /></span>
          <span class="branch-label">{b.label}</span>
          <h3>{b.name}</h3>
          <p>{b.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ============ EXPLORE MORE ============ -->
<section class="ed-section" style="padding-top:0">
  <div class="container">
    <div class="ed-head" data-reveal>
      <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>Explore more</p>
      <h2 class="ed-title">More about us</h2>
    </div>
    <div class="cards-3" data-reveal>
      {explore.map((e) => (
        <a class="info-card link-card" href={e.href}>
          <h3>{e.h}</h3>
          <p>{e.d}</p>
          <span class="link-card__arr">Read more →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ============ CTA ============ -->
<section class="ed-section" style="padding-top:0">
  <div class="container">
    <div class="join-cta" data-reveal>
      <div class="join-cta__img" style="background-image:url('/images/2024/07/Homepage-main-photo.jpg')"></div>
      <div class="join-cta__grade"></div>
      <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>Join us</p>
      <h2>Bring your skills to a global family.</h2>
      <p>Open to all health professionals — Rotarian and non-Rotarian. All it takes is a heart to do good.</p>
      <div class="join-cta__actions">
        <a class="btn btn-primary" href="/membership">Become a member</a>
        <a class="btn btn-outline" href="/contact">Contact us</a>
      </div>
    </div>
  </div>
</section>
</Base>
