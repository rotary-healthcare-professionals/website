---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const items = (await getCollection('news')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const fmt = (d: Date) => d.toISOString().slice(0, 10);
---
<Base
  title="News — International Rotary Fellowship of Healthcare Professionals"
  description="The latest news from the International Rotary Fellowship of Healthcare Professionals — webinars, global grants, service projects and events."
>
  <div class="page-hero">
    <div class="container">
      <p class="crumb"><a href="/">Home</a> / News</p>
      <h1>News</h1>
    </div>
  </div>

  <section>
    <div class="container">
      <div class="news-list">
        {items.map((item) => (
          <article class="news-item">
            {item.data.coverImage && (
              <a href={`/news/${item.id}`} class="thumb-link">
                <img class="thumb" src={item.data.coverImage} alt={item.data.title} loading="lazy" />
              </a>
            )}
            <p class="date">{fmt(item.data.date)}</p>
            <h3><a href={`/news/${item.id}`}>{item.data.title}</a></h3>
            {item.data.summary && <p>{item.data.summary}</p>}
          </article>
        ))}
      </div>
    </div>
  </section>
</Base>
