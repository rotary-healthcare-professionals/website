---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { formatDate as fmt } from '../../lib/date';

const items = (await getCollection('news')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const [featured, ...rest] = items;
---
<Base
  title="News — International Rotary Fellowship of Healthcare Professionals"
  description="The latest news from the International Rotary Fellowship of Healthcare Professionals — webinars, global grants, service projects and events."
>
<!-- ============ HERO ============ -->
<header class="ed-hero" data-reveal>
  <div class="ed-hero__media">
    <div class="ed-hero__img" style="background-image:url('/images/2025/02/tucker-tangeman-584468-unsplash-min-copyright.jpg')"></div>
    <div class="ed-hero__tint"></div>
    <div class="ed-hero__warm"></div>
    <div class="ed-hero__shade"></div>
    <div class="ed-hero__grain"></div>
  </div>
  <div class="container ed-hero__inner">
    <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>News</p>
    <h1 class="display ed-hero__title">Stories from <em>the fellowship.</em></h1>
  </div>
</header>

<section class="ed-section">
  <div class="container">
    {featured && (
      <a class="news-feature" href={`/news/${featured.id}`} data-reveal>
        {featured.data.coverImage
          ? <div class="news-feature__img" style={`background-image:url('${featured.data.coverImage}')`}></div>
          : <div class="news-feature__img news-ph"><svg class="pulse" viewBox="0 0 140 24" fill="none" aria-hidden="true"><path d="M0 12h44l5-9 6 18 5-13 4 9h71" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg></div>}
        <div class="news-feature__body">
          <p class="news-eyebrow">Latest &middot; {fmt(featured.data.date)}</p>
          <h2>{featured.data.title}</h2>
          {featured.data.summary && <p class="news-feature__sum">{featured.data.summary}</p>}
          <span class="news-more">Read the story &rarr;</span>
        </div>
      </a>
    )}

    <div class="news-grid" data-reveal>
      {rest.map((item) => (
        <a class="news-card" href={`/news/${item.id}`}>
          {item.data.coverImage
            ? <div class="news-card__img" style={`background-image:url('${item.data.coverImage}')`}></div>
            : <div class="news-card__img news-ph"><svg class="pulse" viewBox="0 0 140 24" fill="none" aria-hidden="true"><path d="M0 12h44l5-9 6 18 5-13 4 9h71" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg></div>}
          <div class="news-card__body">
            <p class="news-eyebrow">{fmt(item.data.date)}</p>
            <h3>{item.data.title}</h3>
            {item.data.summary && <p class="news-card__sum">{item.data.summary}</p>}
            <span class="news-more news-more--sm">Read more &rarr;</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .news-eyebrow{font-size:.74rem;font-weight:800;letter-spacing:.13em;text-transform:uppercase;color:var(--azure);margin:0}
  .news-more{margin-top:18px;font-weight:800;color:var(--azure);font-size:.92rem;letter-spacing:.01em}
  .news-more--sm{margin-top:auto;padding-top:14px;font-size:.86rem}
  .news-ph{background:linear-gradient(135deg,var(--azure),var(--blue-dark));display:grid;place-items:center;color:rgba(255,255,255,.6)}
  .news-ph .pulse{width:96px;height:auto}

  /* Featured */
  .news-feature{display:grid;grid-template-columns:1.05fr .95fr;background:var(--card);border:1px solid var(--line);border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow);text-decoration:none;margin-bottom:44px;transition:transform .2s,box-shadow .2s}
  .news-feature:hover{transform:translateY(-4px);box-shadow:var(--shadow-lg)}
  .news-feature__img{min-height:320px;background-size:cover;background-position:center}
  .news-feature__body{padding:clamp(28px,3.6vw,52px);display:flex;flex-direction:column;justify-content:center}
  .news-feature__body h2{font-family:var(--serif);font-weight:800;font-size:clamp(1.5rem,3vw,2.25rem);line-height:1.15;letter-spacing:-.01em;color:var(--blue-dark);margin:14px 0 0}
  .news-feature__sum{color:var(--muted);margin-top:15px;line-height:1.6;display:-webkit-box;-webkit-line-clamp:4;-webkit-box-orient:vertical;overflow:hidden}
  @media(max-width:820px){.news-feature{grid-template-columns:1fr}.news-feature__img{min-height:220px}}

  /* Grid */
  .news-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:26px}
  @media(max-width:900px){.news-grid{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:600px){.news-grid{grid-template-columns:1fr}}
  .news-card{display:flex;flex-direction:column;background:var(--card);border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow);text-decoration:none;transition:transform .2s,box-shadow .2s,border-color .2s}
  .news-card:hover{transform:translateY(-5px);box-shadow:var(--shadow-lg);border-color:var(--azure)}
  .news-card__img{aspect-ratio:16/10;background-size:cover;background-position:center;background-color:var(--cloud)}
  .news-card__body{padding:20px 22px 22px;display:flex;flex-direction:column;gap:8px;flex:1}
  .news-card__body h3{font-weight:800;color:var(--blue-dark);font-size:1.06rem;line-height:1.3;margin:2px 0 0}
  .news-card__sum{color:var(--muted);font-size:.9rem;line-height:1.55;margin:0;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
</style>
</Base>
