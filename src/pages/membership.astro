---
import Base from '../layouts/Base.astro';

const JOIN = 'https://membermojo.co.uk/irfhp';

const goals = [
  'Start sustainable health programmes that are built to last.',
  'Volunteer, advise and serve people in need.',
  'Train, teach and advocate for better care.',
  'Work for patient safety and quality of care.',
  'Network and stay in fellowship with colleagues worldwide.',
];

const perks = [
  { t: 'A network in 60 countries', d: 'Doctors, nurses and volunteers you can reach, learn from and work alongside — anywhere in the world.',
    icon: '<path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Z"/><path d="M2 12h20M12 2c3 3 3 17 0 20M12 2c-3 3-3 17 0 20"/>' },
  { t: 'Shared knowledge group', d: 'A members’ group for questions, resources and everyday information sharing.',
    icon: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2Z"/>' },
  { t: 'Educational webinars', d: 'Live online sessions with experts on the health issues we work on.',
    icon: '<rect x="2" y="3" width="20" height="14" rx="2"/><path d="m10 8 4 2.5-4 2.5Z"/><path d="M8 21h8"/>' },
  { t: 'The annual meeting', d: 'Members present their work and outcomes to the whole Fellowship.',
    icon: '<rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>' },
  { t: 'A voice that shapes us', d: 'Life members determine policy, hold office and use our fundraising platforms.',
    icon: '<path d="M12 3 3 8l9 5 9-5-9-5Z"/><path d="M3 8v6M7 10.5V16c0 1 2.2 2.5 5 2.5s5-1.5 5-2.5v-5.5"/>' },
  { t: 'A global community', d: 'Renew old friendships and make new ones — in person at conventions and online.',
    icon: '<circle cx="9" cy="8" r="3"/><path d="M15 11a3 3 0 1 0-2-5.2"/><path d="M3 20c0-3.3 2.7-5 6-5s6 1.7 6 5M15 15c3 0 6 1.7 6 5"/>' },
];
---
<Base
  title={"Membership — International Rotary Fellowship of Healthcare Professionals"}
  description={"Become a member of the International Rotary Fellowship of Healthcare Professionals. Open to all health professionals — Rotarian and non-Rotarian. Life membership £80, Associate £12."}
>
<!-- ============ EDITORIAL HERO ============ -->
<header class="ed-hero" data-reveal>
  <div class="ed-hero__media">
    <div class="ed-hero__img" style="background-image:url('/images/2019/02/NEW-MEMBER.jpg')"></div>
    <div class="ed-hero__tint"></div>
    <div class="ed-hero__warm"></div>
    <div class="ed-hero__shade"></div>
    <div class="ed-hero__grain"></div>
  </div>
  <div class="container ed-hero__inner">
    <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>Membership</p>
    <h1 class="display ed-hero__title">A home for<br>every <em>healer.</em></h1>
  </div>
</header>

<!-- ============ LEAD ============ -->
<section class="ed-section">
  <div class="container ed-head" data-reveal>
    <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>Become a member</p>
    <h2 class="ed-title">Our Fellowship is the natural home of every health professional — Rotarian and non-Rotarian alike.</h2>
    <p class="ed-sub">Practising or retired, wherever you work in the world, there is a place for you here. Membership connects you with colleagues who change lives — and gives you the tools to do the same.</p>
  </div>
</section>

<!-- ============ TIERS ============ -->
<section class="ed-section" id="tiers" style="padding-top:0">
  <div class="container">
    <div class="ed-head" data-reveal>
      <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>Two ways to join</p>
      <h2 class="ed-title">Choose the membership that suits you</h2>
    </div>

    <div class="tiers">
      <article class="tier tier--featured" data-reveal style="--d:.05s">
        <span class="tier__badge">Full voting membership</span>
        <h3 class="tier__name">Life membership</h3>
        <p class="tier__price"><b>£80</b><span>one-time fee</span></p>
        <p class="tier__desc">For practising and retired healthcare professionals who want to stay connected and help others — for life.</p>
        <ul class="tier__feats">
          <li>Attend business meetings and vote on how we’re run</li>
          <li>Take up office and help shape our policies and strategy</li>
          <li>Apply for our mini-grants to launch a project</li>
          <li>Raise funds for your projects through our fundraising platform</li>
          <li>Attend Board meetings as a guest</li>
          <li>Join or sponsor a subgroup or branch</li>
          <li>Nominate a colleague for special recognition</li>
        </ul>
        <a class="btn btn-blue" href={JOIN} target="_blank" rel="noopener">Become a Life member</a>
      </article>

      <article class="tier" data-reveal style="--d:.14s">
        <span class="tier__badge">A perfect first step</span>
        <h3 class="tier__name">Associate membership</h3>
        <p class="tier__price"><b>£12</b><span>one-time fee</span></p>
        <p class="tier__desc">For those getting involved through a subgroup or branch who want to put their energy into focused work.</p>
        <ul class="tier__feats">
          <li>Attend all business meetings as a non-voting member</li>
          <li>Join one or more subgroups and branches</li>
          <li>Contribute to the activities of a branch or subgroup</li>
          <li>Connect with our international members on social media</li>
        </ul>
        <a class="btn btn-blue" href={JOIN} target="_blank" rel="noopener">Become an Associate</a>
      </article>
    </div>

    <p class="tiers-note" data-reveal>
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/></svg>
      Membership fees cover only our very small administrative costs — every other contribution goes straight to the work.
    </p>
  </div>
</section>

<!-- ============ VISION BAND ============ -->
<section class="vision ed-section" data-reveal>
  <div class="container">
    <svg class="pulse" viewBox="0 0 140 24" fill="none" aria-hidden="true"><path d="M0 12h44l5-9 6 18 5-13 4 9h71" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
    <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>Our vision</p>
    <blockquote>To deliver and support safe and respectful health care — <em>every time, everywhere.</em></blockquote>
  </div>
</section>

<!-- ============ GOALS ============ -->
<section class="ed-section">
  <div class="container">
    <div class="ed-head" data-reveal>
      <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>What we stand for</p>
      <h2 class="ed-title">Five commitments we make together</h2>
    </div>
    <div class="goals">
      {goals.map((g, i) => (
        <div class="goal" data-reveal style={`--d:${i * 0.06}s`}>
          <span class="goal__n">{String(i + 1).padStart(2, '0')}</span>
          <p class="goal__t">{g}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ============ PERKS ============ -->
<section class="ed-section" style="padding-top:0">
  <div class="container">
    <div class="ed-head" data-reveal>
      <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>Networking · why members join</p>
      <h2 class="ed-title">Connecting with colleagues around the world</h2>
      <p class="ed-sub">Something so simple — yet so effective in saving lives. There has never been a greater need for healthcare professionals to connect and share.</p>
    </div>
    <div class="perks">
      {perks.map((p, i) => (
        <article class="perk" data-reveal style={`--d:${(i % 3) * 0.08}s`}>
          <span class="perk__ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={p.icon} /></span>
          <h3>{p.t}</h3>
          <p>{p.d}</p>
        </article>
      ))}
    </div>
    <div class="center" style="margin-top:36px" data-reveal>
      <a class="btn btn-ghost" href="/images/2021/11/PROMOTIONAL-PRESENTATION.pdf" target="_blank" rel="noopener">See our promotional presentation (PDF)</a>
    </div>
  </div>
</section>

<!-- ============ CLOSING CTA ============ -->
<section class="ed-section" style="padding-top:0">
  <div class="container">
    <div class="join-cta" data-reveal>
      <div class="join-cta__img" style="background-image:url('/images/2024/07/Homepage-main-photo.jpg')"></div>
      <div class="join-cta__grade"></div>
      <p class="ed-eyebrow"><span class="ed-eyebrow__line"></span>Join us</p>
      <h2>Bring your skills. Change lives.</h2>
      <p>All it takes is a heart to do good in the world and help those in need. Join the fellowship today.</p>
      <div class="join-cta__actions">
        <a class="btn btn-primary" href={JOIN} target="_blank" rel="noopener">Become a member</a>
        <a class="btn btn-outline" href="/contact">Talk to us first</a>
      </div>
    </div>
  </div>
</section>
</Base>
