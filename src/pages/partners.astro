---
<Base title={"Our partners — International Rotary Fellowship of Healthcare Professionals"} description={"Rotary clubs and partners around the world who share their health programmes and collaborate with the International Rotary Fellowship of Healthcare Professionals."}>
<div class="page-hero">
  <div class="container">
    <p class="crumb"><a href="/">Home</a> / Membership</p>
    <h1>Our partners</h1>
  </div>
</div>

<section>
  <div class="container">
    <p class="section-lead" style="margin-bottom:6px">Rotary clubs around the world have shared details of their health programmes with us. If you would like your club&rsquo;s programme to be listed, please <a href="/contact">contact us</a>.</p>

    <div class="partner-grid">
      {partners.map((p) => (
        <article class="partner-card">
          <header>
            <h3>{p.club}</h3>
            <div class="meta">
              <span class="person">{p.contact}</span>
              {p.district && <span class="dist">{p.district}</span>}
            </div>
            {p.email && <a class="email" href={`mailto:${p.email}`}>{p.email}</a>}
          </header>
          <dl>
            {p.summary && (<><dt>Health programme</dt><dd>{p.summary}</dd></>)}
            {p.countries && (<><dt>Countries of operation</dt><dd>{p.countries}</dd></>)}
            {p.future && (<><dt>Plans for the future</dt><dd>{p.future}</dd></>)}
            {p.collab && (<><dt>How we might collaborate</dt><dd>{p.collab}</dd></>)}
          </dl>
        </article>
      ))}
    </div>
  </div>
</section>
</Base>
