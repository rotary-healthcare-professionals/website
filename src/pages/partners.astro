    countries: "Brazil",
    future: "Reach other countries. Translate books. Release videos in English.",
    collab: "Take care of your mental health, and let's help each other spread these ideas.",
    district: "District 7561",
  },
  {
    club: "Rotary Club of el Tahrir",
