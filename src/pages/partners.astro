    countries: "Venezuela",
    future: "Mantener el ejercicio de la profesión.",
    collab: "Pudieran enviarme mensajes.",
    district: "District 4370",
  },
  {
    club: "Rotary Club of Bangalore South",
    contact: "Dr Prafulla Thumati",
    email: "thumatiprafulla@gmail.com",
    summary: "We run many oral check-up camps and treatment camps, giving more importance to oral cancer screening.",
    countries: "India",
