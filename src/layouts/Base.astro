---
interface Props {
  title: string;
  description?: string;
}
const { title, description = '' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<script is:inline>document.documentElement.classList.add('has-js');</script>
<title>{title}</title>
{description && <meta name="description" content={description} />}
<link rel="icon" href="/images/2025/02/RFHP_Logofinal_round-105x83.png" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Libre+Franklin:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/style.css" />
</head>
<body>

<header class="site-header">
  <div class="container">
    <a class="brand" href="/">
      <img src="/images/2025/02/RFHP_Logofinal_round-105x83.png" alt="IRFHP logo" />
      <span>International Rotary Fellowship<br />of Healthcare Professionals</span>
    </a>
    <button class="nav-toggle" aria-label="Open menu" aria-controls="mainNav" aria-expanded="false" type="button">
      <span></span><span></span><span></span>
    </button>
    <nav class="main-nav" id="mainNav">
      <button class="nav-close" aria-label="Close menu" type="button">&times;</button>
      <div><a href="/">Home</a></div>
      <div class="has-dropdown">
        <a href="/projects">Service projects</a>
        <button class="submenu-toggle" type="button" aria-label="Toggle Service projects submenu" aria-expanded="false"><span class="caret">▾</span></button>
        <div class="dropdown">
          <a href="/kmc">Kangaroo Mother Care (KMC)</a>
          <a href="/cervical-cancer">Cervical cancer</a>
          <a href="/ukraine">Helping Ukraine</a>
          <a href="/education">Educational Activities</a>
          <a href="/quality-safety">Quality and Safety in Healthcare</a>
          <a href="/tanzania">Tanzania: transforming lives</a>
        </div>
      </div>
      <div><a href="/news">News</a></div>
      <div class="has-dropdown">
        <a href="/about">About us</a>
        <button class="submenu-toggle" type="button" aria-label="Toggle About us submenu" aria-expanded="false"><span class="caret">▾</span></button>
        <div class="dropdown">
          <a href="/our-journey">Our Journey</a>
          <a href="/heritage">Our Heritage</a>
          <a href="/board">Our Board and Accounts</a>
          <a href="/directory">A Directory of Health Programmes</a>
          <a href="/conventions">Rotary International Conventions</a>
        </div>
      </div>
      <div class="has-dropdown">
        <a class="nav-trigger" role="button" tabindex="0" aria-haspopup="true">Membership</a>
        <button class="submenu-toggle" type="button" aria-label="Toggle Membership submenu" aria-expanded="false"><span class="caret">▾</span></button>
        <div class="dropdown">
          <a href="/membership">Our membership</a>
          <a href="/partners">Our partners</a>
        </div>
      </div>
      <div><a href="/contact">Contact</a></div>
      <div class="donate-item"><a class="btn btn-primary" href="/donate">Donate</a></div>
    </nav>
  </div>
</header>

<slot />

<footer class="site-footer">
  <div class="container top">
    <div>
      <img src="/images/2025/02/RFHP_Logofinal_round-300x238.png" alt="IRFHP logo" />
      <p>Highfield House, Red Shute Hill, Thatcham, RG18 9QH<br />United Kingdom</p>
      <p>E-mail: <a href="mailto:rotaryhealthprofessionals@gmail.com">rotaryhealthprofessionals@gmail.com</a></p>
      <p><a class="social-link" href="https://www.facebook.com/people/Fellowship-of-Healthcare-Professionals/100080617180613/" target="_blank" rel="noopener" aria-label="Follow us on Facebook"><span class="fb" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M13.5 21v-7h2.35l.4-3H13.5V9.05c0-.87.28-1.46 1.53-1.46H16.4V4.9c-.28-.04-1.23-.12-2.34-.12-2.32 0-3.9 1.42-3.9 4.02V11H7.8v3h2.36v7h3.34Z"/></svg></span>Facebook</a></p>
    </div>
    <div class="links">
      <h4>Quick links</h4>
      <a href="/projects">Service projects</a>
      <a href="/news">News</a>
      <a href="/about">About us</a>
      <a href="/membership">Membership</a>
      <a href="/contact">Contact</a>
    </div>
    <div class="links">
      <h4>Get involved</h4>
      <a href="/donate">Donate</a>
      <a href="https://membermojo.co.uk/irfhp" target="_blank" rel="noopener">Members area</a>
      <a href="https://form.jotform.com/232014525247852" target="_blank" rel="noopener">Register a health programme</a>
      <a href="/partners">Our partners</a>
    </div>
  </div>
  <div class="container bottom">
    <span>Copyright © <span id="god"></span> International Rotary Fellowship of Healthcare Professionals</span>
    <span>This fellowship is not an agency of, or controlled by, Rotary International.</span>
  </div>
</footer>

<script is:inline>document.getElementById('god').textContent = new Date().getFullYear();</script>
<script is:inline>
/* Dokumenti u sadržaju:
   - PDF unutar vijesti (/news/...) -> ugrađeni prikaz (iframe desktop / kartica mobitel)
   - svi ostali dokumenti (PDF na stranicama, Word, Excel, PowerPoint) -> uredna "dokument-kartica" za preuzimanje
   Zatim: vanjski linkovi u sadržaju dobiju malu strelicu ↗. */
(function () {
  var isNews = /\/news\//.test(location.pathname);
  var TYPES = {
    pdf:  { css: 'doc-pdf',   ico: 'PDF', label: 'PDF document' },
    doc:  { css: 'doc-word',  ico: 'DOC', label: 'Word document' },
    docx: { css: 'doc-word',  ico: 'DOC', label: 'Word document' },
    xls:  { css: 'doc-excel', ico: 'XLS', label: 'Excel spreadsheet' },
    xlsx: { css: 'doc-excel', ico: 'XLS', label: 'Excel spreadsheet' },
    ppt:  { css: 'doc-ppt',   ico: 'PPT', label: 'PowerPoint' },
    pptx: { css: 'doc-ppt',   ico: 'PPT', label: 'PowerPoint' }
  };
  var seen = {};
  [].forEach.call(document.querySelectorAll('.prose a[href]'), function (a) {
    if (!a.isConnected) return;
    if (a.querySelector('img')) return;                 // slika-link ostaje netaknut
    var href = a.getAttribute('href'); if (!href) return;
    var m = href.split('?')[0].split('#')[0].match(/\.([a-z0-9]+)$/i);
    if (!m) return;
    var ext = m[1].toLowerCase();
    var t = TYPES[ext]; if (!t) return;

    if (seen[href]) {                                   // isti dokument naveden dvaput
      var dp = a.closest('li') || a.closest('p'); a.remove();
      if (dp && !dp.textContent.trim() && !dp.querySelector('img, a')) dp.remove();
      return;
    }
    seen[href] = true;

    var label = (a.textContent || '').trim();
    if (!label || /^(download|pdf|click here|more information)$/i.test(label)) {
      label = decodeURIComponent(href.split('/').pop().replace(/\.[a-z0-9]+$/i, '')).replace(/[-_]+/g, ' ').trim();
    }
    var container = a.closest('li') || a.closest('p') || a;

    /* PDF u vijesti -> ugrađeni prikaz */
    if (ext === 'pdf' && isNews) {
      var fig = document.createElement('figure');
      fig.className = 'pdf-doc';
      var frame = document.createElement('iframe');
      frame.className = 'pdf-frame'; frame.src = href; frame.title = label; frame.loading = 'lazy';
      var mc = document.createElement('a');
      mc.className = 'pdf-card'; mc.href = href; mc.target = '_blank'; mc.rel = 'noopener';
      var mi = document.createElement('span'); mi.className = 'pdf-ico'; mi.textContent = 'PDF';
      var mm = document.createElement('span'); mm.className = 'pdf-meta';
      var mn = document.createElement('span'); mn.className = 'pdf-name'; mn.textContent = label;
      var ms = document.createElement('span'); ms.className = 'pdf-sub'; ms.textContent = 'Open document';
      mm.appendChild(mn); mm.appendChild(ms);
      var ma = document.createElement('span'); ma.className = 'pdf-open'; ma.textContent = '›';
      mc.appendChild(mi); mc.appendChild(mm); mc.appendChild(ma);
      var open = document.createElement('a');
      open.className = 'pdf-openfull'; open.href = href; open.target = '_blank'; open.rel = 'noopener';
      open.textContent = 'Open full screen / download';
      fig.appendChild(frame); fig.appendChild(mc); fig.appendChild(open);
      container.parentNode.replaceChild(fig, container);
      return;
    }

    /* Sve ostalo -> dokument-kartica za preuzimanje */
    var card = document.createElement('a');
    card.className = 'doc-card'; card.href = href; card.target = '_blank'; card.rel = 'noopener';
    var ico = document.createElement('span'); ico.className = 'doc-ico ' + t.css; ico.textContent = t.ico;
    var meta = document.createElement('span'); meta.className = 'doc-meta';
    var nm = document.createElement('span'); nm.className = 'doc-name'; nm.textContent = label;
    var sub = document.createElement('span'); sub.className = 'doc-sub'; sub.textContent = t.label + ' · Download';
    meta.appendChild(nm); meta.appendChild(sub);
    var arr = document.createElement('span'); arr.className = 'doc-open'; arr.textContent = '↓';
    card.appendChild(ico); card.appendChild(meta); card.appendChild(arr);
    container.parentNode.replaceChild(card, container);
  });

  /* Vanjski linkovi u sadržaju -> mala strelica ↗ (ne dira gumbe ni slika-linkove) */
  var host = location.hostname;
  [].forEach.call(document.querySelectorAll('.prose a[href^="http"]'), function (a) {
    if (a.classList.contains('btn')) return;
    if (a.querySelector('img')) return;
    var u; try { u = new URL(a.href); } catch (e) { return; }
    if (u.hostname === host) return;
    a.setAttribute('target', '_blank'); a.setAttribute('rel', 'noopener');
    var s = document.createElement('span');
    s.className = 'ext-arrow'; s.setAttribute('aria-hidden', 'true'); s.textContent = '↗';
    a.appendChild(s);
  });
})();
</script>
<script is:inline>
(function () {
  var nav = document.getElementById('mainNav');
  if (!nav) return;
  var toggle = document.querySelector('.nav-toggle');
  var closeBtn = nav.querySelector('.nav-close');

  // otvori podizbornik koji sadrži trenutnu stranicu
  function expandCurrent() {
    var here = (location.pathname || '/').replace(/\/+$/, '') || '/';
    nav.querySelectorAll('.has-dropdown').forEach(function (item) {
      var match = [].some.call(item.querySelectorAll('a'), function (a) {
        return (a.pathname || '').replace(/\/+$/, '') === here;
      });
      if (match) {
        item.classList.add('expanded');
        var t = item.querySelector('.submenu-toggle');
        if (t) t.setAttribute('aria-expanded', 'true');
      }
    });
  }

  function openNav() {
    expandCurrent();
    nav.classList.add('open');
    document.body.classList.add('nav-open');
    if (toggle) toggle.setAttribute('aria-expanded', 'true');
  }
  function closeNav() {
    nav.classList.remove('open');
    document.body.classList.remove('nav-open');
    nav.querySelectorAll('.has-dropdown.expanded').forEach(function (item) {
      item.classList.remove('expanded');
      var t = item.querySelector('.submenu-toggle');
      if (t) t.setAttribute('aria-expanded', 'false');
    });
    if (toggle) toggle.setAttribute('aria-expanded', 'false');
  }
  if (toggle) toggle.addEventListener('click', function () {
    if (nav.classList.contains('open')) closeNav(); else openNav();
  });
  if (closeBtn) closeBtn.addEventListener('click', closeNav);

  nav.querySelectorAll('.submenu-toggle').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.preventDefault();
      e.stopPropagation();
      var item = btn.closest('.has-dropdown');
      if (!item) return;
      var willOpen = !item.classList.contains('expanded');
      // harmonika: zatvori sve druge otvorene podizbornike
      nav.querySelectorAll('.has-dropdown.expanded').forEach(function (other) {
        if (other !== item) {
          other.classList.remove('expanded');
          var ot = other.querySelector('.submenu-toggle');
          if (ot) ot.setAttribute('aria-expanded', 'false');
        }
      });
      item.classList.toggle('expanded', willOpen);
      btn.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
    });
  });

  // Bezhref roditeljski trigger (npr. "Membership") — tap na naziv otvara/zatvara
  // podizbornik jednako kao strelica. Linkovi s href-om (Service projects, About us)
  // ostaju obična navigacija.
  nav.querySelectorAll('.has-dropdown > a:not([href])').forEach(function (trigger) {
    var btn = trigger.parentNode.querySelector('.submenu-toggle');
    if (!btn) return;
    trigger.addEventListener('click', function (e) {
      e.preventDefault();
      btn.click();
    });
    trigger.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ' || e.key === 'Spacebar') {
        e.preventDefault();
        btn.click();
      }
    });
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && nav.classList.contains('open')) closeNav();
  });
  window.addEventListener('resize', function () {
    if (window.innerWidth > 760 && nav.classList.contains('open')) closeNav();
  });
})();
</script>
<script is:inline>
/* Reveal-on-scroll: progresivno poboljšanje. Bez JS-a ili uz reduced-motion sadržaj je odmah vidljiv. */
(function () {
  var els = [].slice.call(document.querySelectorAll('[data-reveal]'));
  if (!els.length) return;
  var reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
  if (!('IntersectionObserver' in window) || reduce.matches) {
    els.forEach(function (el) { el.classList.add('is-visible'); });
    return;
  }
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
    });
  }, { rootMargin: '0px 0px -8% 0px', threshold: 0.12 });
  els.forEach(function (el) { io.observe(el); });
})();
</script>
</body>
</html>
